# Sigstore provenance attestation on every publish (ADR-0012 S-1).
# `provenance` is an rc option for `pnpm publish` (which changesets shells out
# to) — publishConfig.provenance and uppercase NPM_CONFIG_* env vars are npm-CLI
# mechanisms pnpm ignores (proven by the unattested 0.1.0/0.1.1 releases).
# Side effect by design: `pnpm publish` outside a supported CI fails, which
# enforces the CI-only release policy.
provenance=true
