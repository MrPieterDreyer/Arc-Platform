  "plugins": [
    "https://downloads.wordpress.org/plugin/woocommerce.latest-stable.zip",
    "https://downloads.wordpress.org/plugin/wp-graphql.latest-stable.zip",
    "https://github.com/wp-graphql/wp-graphql-woocommerce/releases/download/v1.0.2/wp-graphql-woocommerce.zip"
  ],
  "port": 8888,
  "testsPort": 8889,
  "config": {
    "WP_DEBUG": true,
    "SCRIPT_DEBUG": false,
    "GRAPHQL_DEBUG": true
  },
  "mappings": {
    "wp-content/arc-seed": "./Scripts/wp-seed",
    "wp-content/plugins/weave": "./Weave/WordPress"
  }
}
