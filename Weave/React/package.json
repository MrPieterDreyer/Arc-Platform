{
  "name": "@weave/react",
  "version": "0.0.1",
  "private": false,
  "description": "Weave — sections schema SDK for React",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "biome lint ./src",
    "test": "vitest"
  },
  "peerDependencies": {
    "react": "catalog:"
  }
}
