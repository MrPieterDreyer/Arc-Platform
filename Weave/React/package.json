{
  "name": "@weave/react",
  "version": "0.0.1",
  "private": false,
  "description": "Weave — sections schema SDK for React",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint ./src",
    "format:check": "biome format ./src",
    "test": "vitest --run"
  },
  "peerDependencies": {
    "react": "catalog:"
  },
  "devDependencies": {
    "jsdom": "^29.1.1"
  }
}
