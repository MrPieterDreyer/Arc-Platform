{
  "name": "@weave-platform/react",
  "version": "0.1.2",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Weave — sections schema SDK for React",
  "license": "MIT",
  "author": "Pieter Dreyer",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrPieterDreyer/arc-platform.git",
    "directory": "Weave/React"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.mjs",
      "require": "./dist/schemas.js"
    }
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "dependencies": {
    "client-only": "^0.0.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^29.1.1",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint ./src",
    "format:check": "biome format ./src",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  }
}
