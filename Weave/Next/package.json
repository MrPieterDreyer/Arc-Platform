{
  "name": "@weave/next",
  "version": "0.0.1",
  "private": false,
  "description": "Weave — Next.js App Router integration for sections",
  "license": "MIT",
  "author": "Pieter Dreyer",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrPieterDreyer/arc-platform.git",
    "directory": "Weave/Next"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint ./src",
    "format:check": "biome format ./src",
    "test": "vitest --run"
  },
  "peerDependencies": {
    "next": "catalog:",
    "react": "catalog:"
  },
  "dependencies": {
    "@weave/react": "workspace:^"
  }
}
