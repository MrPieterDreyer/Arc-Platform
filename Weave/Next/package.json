{
  "name": "@weave-platform/next",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Weave — Next.js App Router integration for sections",
  "license": "MIT",
  "author": "Pieter Dreyer",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrPieterDreyer/arc-platform.git",
    "directory": "Weave/Next"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./server-page": {
      "types": "./dist/server-page.d.ts",
      "import": "./dist/server-page.mjs",
      "require": "./dist/server-page.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint ./src",
    "format:check": "biome format ./src",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": "catalog:",
    "react": "catalog:"
  },
  "dependencies": {
    "@arc-platform/next": "workspace:^",
    "@weave-platform/react": "workspace:^",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.0",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
