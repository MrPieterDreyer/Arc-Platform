{
  "name": "@arc-platform/next",
  "version": "0.1.3",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Arc — Next.js App Router integration",
  "license": "MIT",
  "author": "Pieter Dreyer",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrPieterDreyer/arc-platform.git",
    "directory": "Arc/Next"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint ./src",
    "format:check": "biome format ./src",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": "catalog:",
    "react": "catalog:"
  },
  "dependencies": {
    "@arc-platform/core": "workspace:^",
    "client-only": "^0.0.1",
    "graphql-request": "catalog:",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "^19.2.15",
    "jsdom": "^29.1.1",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
