{
  "name": "@arc/core",
  "version": "0.0.1",
  "private": false,
  "description": "Arc — WooCommerce Store API client, hooks, and TypeScript types",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "dependencies": {
    "graphql": "catalog:",
    "graphql-request": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/client-preset": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "^19.2.15",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint ./src",
    "format:check": "biome format ./src",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts"
  }
}
