{
  "name": "arc-platform",
  "private": true,
  "version": "0.0.0",
  "description": "Arc headless WooCommerce framework + Weave visual editor",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=11.4.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "license-check": "node Scripts/check-licenses.mjs",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish",
    "verify-adrs": "node Scripts/verify-adrs.mjs",
    "verify-dist": "node Scripts/verify-dist.mjs",
    "verify-turbo-cache": "bash Scripts/verify-turbo-cache.sh",
    "verify-changesets-no-major": "node Scripts/verify-changesets-no-major.mjs",
    "verify-changesets-config": "node Scripts/verify-changesets-config.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/changelog-github": "0.5.0",
    "@changesets/cli": "2.31.0",
    "@vitest/coverage-v8": "4.1.7",
    "tsup": "8.5.1",
    "turbo": "2.9.15",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
