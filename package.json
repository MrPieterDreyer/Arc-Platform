{
  "name": "arc-platform",
  "private": true,
  "version": "0.0.0",
  "description": "Arc headless WooCommerce framework + Weave visual editor",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11.4.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "test:contract": "dotenv -e .env.wp-test -- pnpm --filter @arc/core --filter @arc/next test",
    "test:e2e:smoke": "dotenv -e .env.wp-test -- turbo run test:e2e:smoke --filter @arc/next-example",
    "test:e2e:integration": "dotenv -e .env.wp-test -- turbo run test:e2e:integration --filter @arc/next-example",
    "test:e2e:catalog": "dotenv -e .env.wp-test -- turbo run test:e2e:catalog --filter @arc/next-example",
    "test:e2e:cart": "dotenv -e .env.wp-test -- turbo run test:e2e:cart --filter @arc/next-example",
    "test:e2e:weave": "dotenv -e .env.wp-test -- turbo run test:e2e:weave --filter @arc/next-example",
    "test:e2e:checkout": "dotenv -e .env.wp-test -- turbo run test:e2e:checkout --filter @arc/next-example",
    "test:e2e:account": "dotenv -e .env.wp-test -- turbo run test:e2e:account --filter @arc/next-example",
    "test:e2e:payment": "dotenv -e .env.wp-test -- turbo run test:e2e:payment --filter @arc/next-example",
    "test:e2e:visual": "dotenv -e .env.wp-test -- turbo run test:e2e:visual --filter @arc/next-example",
    "test:e2e:a11y": "dotenv -e .env.wp-test -- turbo run test:e2e:a11y --filter @arc/next-example",
    "test:e2e:perf": "dotenv -e .env.wp-test -- turbo run test:e2e:perf --filter @arc/next-example",
    "test:e2e:weave-wp": "dotenv -e .env.wp-test -- pnpm --filter @arc/next-example exec playwright test --config ../../../../Weave/WordPress/playwright.config.cjs",
    "test:e2e": "dotenv -e .env.wp-test -- turbo run test:e2e --filter @arc/next-example",
    "test:e2e:nightly": "dotenv -e .env.wp-test -- turbo run test:e2e:nightly --filter @arc/next-example",
    "typecheck": "turbo run typecheck",
    "wp:start": "wp-env start",
    "wp:stop": "wp-env stop",
    "wp:destroy": "wp-env destroy",
    "wp:seed": "node Scripts/seed-wp-env.mjs",
    "wp:setup": "wp-env start && node Scripts/seed-wp-env.mjs",
    "license-check": "node Scripts/check-licenses.mjs",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish",
    "verify-adrs": "node Scripts/verify-adrs.mjs",
    "verify-dist": "node Scripts/verify-dist.mjs",
    "verify-turbo-cache": "bash Scripts/verify-turbo-cache.sh",
    "verify-changesets-no-major": "node Scripts/verify-changesets-no-major.mjs",
    "verify-changesets-config": "node Scripts/verify-changesets-config.mjs",
    "verify-ci-workflow": "node Scripts/verify-ci-workflow.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@vitest/coverage-v8": "4.1.8",
    "@wordpress/env": "^11.7.0",
    "dotenv-cli": "^11.0.0",
    "tsup": "8.5.1",
    "turbo": "2.9.16",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
