{
  "$schema": "https://unpkg.com/@changesets/config@3.1.1/schema.json",
  "changelog": ["@changesets/changelog-github", { "repo": "MrPieterDreyer/arc-platform" }],
  "commit": false,
  "fixed": [["@arc-platform/*"], ["@weave-platform/*"]],
  "linked": [],
  "access": "public",
  "baseBranch": "master",
  "updateInternalDependencies": "patch",
  "ignore": ["@arc-platform/next-example"],
  "snapshot": {
    "useCalculatedVersion": true,
    "prereleaseTemplate": "0.0.0-snapshot-{datetime}"
  }
}
