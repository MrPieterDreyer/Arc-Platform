# Arc Platform — environment variables example
# Copy to .env and fill in values for local development.
# Never commit .env — it is gitignored.

# ---------------------------------------------------------------------------
# WPGraphQL — graphql-codegen + catalog queries
# ---------------------------------------------------------------------------
# Full URL to the WPGraphQL endpoint (used by codegen and GQL queries at runtime)
WP_GRAPHQL_ENDPOINT=http://localhost:8888/graphql
# Optional: JWT or Application Password token for authenticated GQL queries
WP_GRAPHQL_TOKEN=

# ---------------------------------------------------------------------------
# WooCommerce — wp-env local site (contract tests + Store API)
# ---------------------------------------------------------------------------
# Base URL of the local WordPress site (wp-env default)
WP_URL=http://localhost:8888

# ---------------------------------------------------------------------------
# Contract test fixtures
# Seed these values in wp-env before running contract tests.
# ---------------------------------------------------------------------------
# ID of a simple product to use in cart tests
TEST_PRODUCT_ID=1
# Slug of a simple product for GQL product tests
TEST_PRODUCT_SLUG=test-product
# Slug of a variable product for variation tests
TEST_VARIABLE_PRODUCT_SLUG=test-variable
# Slug of a product category for collection tests
TEST_COLLECTION_SLUG=uncategorized
# Coupon code to use in coupon tests (must be seeded in WC)
TEST_COUPON_CODE=TEST10
# ID of a completed order for order retrieval tests (set after first checkout test run)
TEST_ORDER_ID=
# JWT token for authenticated customer GQL tests (generate via WP JWT plugin)
TEST_JWT_TOKEN=

# ---------------------------------------------------------------------------
# Contract test gate
# Set to any non-empty value to enable contract tests.
# Requires: running wp-env + Docker + seeded fixtures above.
# ---------------------------------------------------------------------------
CI_WP_ENV=

# ---------------------------------------------------------------------------
# @arc/next — Next.js integration (Phase 2+)
# ---------------------------------------------------------------------------
ARC_WC_URL=http://localhost:8888
ARC_GRAPHQL_ENDPOINT=http://localhost:8888/graphql
WEAVE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Weave @weave/next — server-to-server page-config reads (D-04a)
# loadPageConfig(slug) authenticates to weave/v1 with a WP Application Password.
# ---------------------------------------------------------------------------
# WordPress site origin. HTTPS is REQUIRED for WP Application Passwords except on
# localhost (Pitfall 6). No trailing slash needed.
WEAVE_WP_BASE_URL=https://your-wp-site.example
# The WP user the Application Password belongs to.
WEAVE_WP_APP_USER=admin
# WP Application Password — generated WITH spaces; store verbatim (quote if your
# shell/loader strips spaces).
WEAVE_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# Draft-preview token gating draftMode() preview links (Plan 03).
WEAVE_PREVIEW_SECRET=
# Shared HMAC secret with the Weave WP plugin (Plan 04). MUST be the SAME value
# the 4a plugin signs revalidation webhooks with.
WEAVE_WEBHOOK_SECRET=
